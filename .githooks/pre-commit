#!/usr/bin/env bash
set -euo pipefail

if ! command -v cargo >/dev/null 2>&1; then
  echo "pre-commit: cargo is not installed or not in PATH" >&2
  exit 1
fi

has_black=true
if ! command -v black >/dev/null 2>&1; then
  has_black=false
  echo "[WARN] pre-commit: black is not installed or not in PATH; skipping Python formatting" >&2
fi

echo "[INFO] pre-commit: running formatters..."
cargo fmt --all
if [ "$has_black" = true ]; then
  black .
fi
echo "[ OK ] pre-commit: running formatters DONE"

echo "[INFO] pre-commit: generating docs..."
cargo doc --workspace --no-deps --quiet
echo "[ OK ] pre-commit: generating docs DONE"

echo "[INFO] pre-commit: running tests..."
cargo test --workspace --quiet
echo "[ OK ] pre-commit: running tests DONE"

# Stage files changed by formatter so commit includes formatting updates.
git add -u
